{
    "name": "retail-atlas",
    "productName": "Retail Atlas",
    "version": "2.0.0",
    "description": "Aether app: Retail Atlas",
    "scripts": {
        "predev": "test -f .env || node init-project.js --local",
        "dev": "nuxt dev",
        "start": "node .output/server/index.mjs",
        "init": "node init-project.js",
        "prebuild": "npm run build:data",
        "build": "NODE_ENV=production NODE_OPTIONS='--max-old-space-size=8192' nuxt build",
        "build:data": "tsx scripts/build-retail-data.ts",
        "build:topojson": "tsx scripts/fetch-topojson.ts",
        "build:coverage": "tsx scripts/build-coverage.ts",
        "db:atlas:setup": "tsx scripts/db-atlas-setup.ts",
        "db:atlas:load": "tsx scripts/load-neon-atlas.ts",
        "db:atlas:parity": "tsx scripts/report-neon-parity.ts",
        "probe:coverage": "tsx scripts/probe-store-coverage.ts",
        "expand:areas": "tsx scripts/expand-area-neids.ts",
        "expand:retailers": "tsx scripts/expand-retailer-neids.ts",
        "probe:event-categories": "tsx scripts/probe-event-categories.ts",
        "probe:event-total": "tsx scripts/probe-event-total.ts",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "format": "prettier --write \"**/*.{js,ts,vue,json,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
        "format:check": "prettier --check \"**/*.{js,ts,vue,json,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
        "postinstall": "npx nuxi prepare",
        "prepare": "husky"
    },
    "lint-staged": {
        "**/*.{js,ts,vue,json,md}": [
            "prettier --check"
        ]
    },
    "dependencies": {
        "@hapi/iron": "^7.0.1",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@neondatabase/serverless": "^1.1.0",
        "@tanstack/vue-virtual": "^3.13.8",
        "@upstash/redis": "^1.37.0",
        "@yottagraph-app/elemental-api": "^1.1.7",
        "chroma-js": "^3.1.2",
        "cors": "^2.8.5",
        "d3": "^7.8.5",
        "dagre": "^0.8.5",
        "express": "^4.18.2",
        "file-saver": "^2.0.5",
        "iron-webcrypto": "^1.2.1",
        "jose": "^5.9.6",
        "localforage": "^1.10.0",
        "mitt": "^3.0.1",
        "prettier": "^3.5.3",
        "topojson-client": "^3.1.0",
        "us-atlas": "^3.0.1",
        "vuetify": "^3.8.5",
        "world-atlas": "^2.0.2"
    },
    "devDependencies": {
        "@mdi/font": "^7.4.47",
        "@types/chroma-js": "^3.1.1",
        "@types/d3": "^7.4.3",
        "@types/dagre": "^0.7.52",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^22.13.4",
        "@vitejs/plugin-vue": "^5.2.1",
        "csv-parse": "^6.2.1",
        "dotenv": "^17.2.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.6",
        "nuxt": "^3.16.0",
        "sass": "^1.84.0",
        "topojson-server": "^3.0.1",
        "topojson-simplify": "^3.0.3",
        "tsx": "^4.21.0",
        "typescript": "^5.7.3",
        "vercel": "^50.13.2",
        "vue": "^3.5.14",
        "vue-router": "^4.5.1",
        "vuetify-nuxt-module": "^0.18.6"
    }
}
